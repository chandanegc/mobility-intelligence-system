
      

      <html>
        <head>
          <title>Editable Polyline</title>
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <meta charset="utf-8">
          <style>
	          html,
	          body,
              #app {
	            margin: 0;
	            padding: 0;
	            width: 100%;
	            height: 100vh;
	          }

              body {
                font-family: Arial, sans-serif;
                overflow: hidden;
              }

              #app {
                display: flex;
              }

              #pointPanel {
                background: #fff;
                border-right: 1px solid #d4d4d4;
                box-sizing: border-box;
                flex: 0 0 320px;
                height: 100vh;
                overflow-y: auto;
                padding: 16px;
                z-index: 2;
              }

              .point-panel-header {
                align-items: center;
                display: flex;
                gap: 12px;
                justify-content: space-between;
                margin-bottom: 12px;
              }

              #pointPanel h2 {
                font-size: 18px;
                margin: 0;
              }

              #visitCountBadge {
                background: #eff6ff;
                border: 1px solid #bfdbfe;
                border-radius: 999px;
                color: #1d4ed8;
                font-size: 12px;
                font-weight: 700;
                padding: 4px 8px;
                white-space: nowrap;
              }

              #menuButton,
              #closePanelButton {
                align-items: center;
                background: #fff;
                border: 1px solid #d4d4d4;
                border-radius: 8px;
                color: #111827;
                cursor: pointer;
                display: none;
                height: 44px;
                justify-content: center;
                width: 44px;
              }

              #menuButton {
                box-shadow: 0 4px 14px rgba(0, 0, 0, .18);
                left: 14px;
                position: fixed;
                top: 14px;
                z-index: 4;
              }

              #closePanelButton {
                flex: 0 0 38px;
                height: 38px;
                width: 38px;
              }

              #menuButton span,
              #closePanelButton span {
                font-size: 24px;
                line-height: 1;
              }

              #panelBackdrop {
                background: rgba(17, 24, 39, .36);
                display: none;
                inset: 0;
                position: fixed;
                z-index: 2;
              }

              #pointList {
                display: grid;
                gap: 10px;
              }

              .prediction-controls {
                border-bottom: 1px solid #e5e7eb;
                display: grid;
                gap: 10px;
                margin: 0 -16px 14px;
                padding: 0 16px 14px;
              }

              .control-label {
                color: #374151;
                display: grid;
                font-size: 12px;
                font-weight: 700;
                gap: 6px;
              }

              .control-input {
                border: 1px solid #d1d5db;
                border-radius: 6px;
                box-sizing: border-box;
                color: #111827;
                font-size: 14px;
                height: 38px;
                padding: 0 10px;
                width: 100%;
              }

              .prediction-actions {
                display: grid;
                gap: 8px;
                grid-template-columns: 1fr 1fr;
              }

              .prediction-button {
                background: #111827;
                border: 1px solid #111827;
                border-radius: 6px;
                color: #fff;
                cursor: pointer;
                font-size: 13px;
                font-weight: 700;
                height: 38px;
              }

              .prediction-button.secondary {
                background: #fff;
                color: #111827;
              }

              .prediction-button:disabled {
                cursor: not-allowed;
                opacity: .55;
              }

              .point-list-state {
                border: 1px dashed #d1d5db;
                border-radius: 8px;
                color: #4b5563;
                font-size: 13px;
                line-height: 1.45;
                padding: 12px;
              }

              .point-item {
                border: 1px solid #e5e7eb;
                border-radius: 8px;
                cursor: pointer;
                padding: 10px;
              }

              .point-item:hover {
                border-color: #1d4ed8;
              }

              .point-item.active {
                background: #eff6ff;
                border-color: #1d4ed8;
              }

              .point-title {
                color: #1d4ed8;
                font-size: 14px;
                font-weight: 700;
                margin-bottom: 6px;
              }

              .point-meta {
                color: #333;
                font-size: 13px;
                line-height: 1.5;
              }

              #map {
                flex: 1;
                height: 100vh;
                min-width: 0;
              }

              @media (max-width: 768px) {
                #app {
                  display: block;
                }

                #menuButton {
                  display: flex;
                }

                #pointPanel {
                  border-right: 0;
                  border-radius: 16px 16px 0 0;
                  bottom: 0;
                  box-shadow: 0 -10px 30px rgba(0, 0, 0, .22);
                  height: 72vh;
                  left: 0;
                  max-height: 620px;
                  overflow-y: auto;
                  padding: 16px;
                  position: fixed;
                  right: 0;
                  transform: translateY(105%);
                  transition: transform .22s ease;
                  z-index: 3;
                }

                body.panel-open #pointPanel {
                  transform: translateY(0);
                }

                body.panel-open #panelBackdrop {
                  display: block;
                }

                body.panel-open #menuButton {
                  display: none;
                }

                #closePanelButton {
                  display: flex;
                }

                .point-panel-header {
                  border-bottom: 1px solid #e5e7eb;
                  margin: 0 -16px 12px;
                  padding: 0 16px 12px;
                  position: sticky;
                  top: -16px;
                  background: #fff;
                  z-index: 1;
                }

                #map {
                  height: 100vh;
                  width: 100%;
                }
              }

		          </style>
             <script src="https://sdk.mappls.com/map/sdk/web?v=3.0&access_token=vokkcycrqlivzvdfngabetjfojmgdzubghbx&callback=initMap1" defer async></script>
            </head>
        <body>
                    <div id="app">
                        <button id="menuButton" type="button" aria-label="Open visit points" aria-controls="pointPanel" aria-expanded="false">
                            <span aria-hidden="true">&#9776;</span>
                        </button>
                        <div id="panelBackdrop"></div>
                        <aside id="pointPanel">
                            <div class="point-panel-header">
                                <div>
                                    <h2>User Clusters</h2> <br>
                                    <span id="visitCountBadge">Cluster Count: 0</span>
                                </div>
                                <button id="closePanelButton" type="button" aria-label="Close visit points">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="prediction-controls">
                                <label class="control-label">
                                    Day
                                    <input id="predictionDate" class="control-input" type="date">
                                </label>
                                <label class="control-label">
                                    Time
                                    <input id="predictionTime" class="control-input" type="time">
                                </label>
                                <div class="prediction-actions">
                                    <button id="predictDayButton" class="prediction-button" type="button">Day Route</button>
                                    <button id="predictTimeButton" class="prediction-button secondary" type="button">Time Point</button>
                                </div>
                            </div>
                            <div id="pointList"></div>
                        </aside>
	                    <div id="map"></div>
                    </div>
	                        <script>
		        var map,polylines = [],markers = [],markerPositions = [];
            var activePoints = [];
            var currentBadgeLabel = 'Cluster Count';
            var userId = 'U123';

            function buildApiUrl(path, params) {
                var query = new URLSearchParams(params);
                return path + '?' + query.toString();
            }

	        async function loadUserClusterPoints() {
	            const response = await fetch(buildApiUrl('/api/user-clusters/polyline', { user_id: userId }));

            if (!response.ok) {
                throw new Error('Failed to load user cluster points');
            }

            const data = await response.json();
            var points = data.points || [];
            updateVisitCount(data.count || points.length);
	            return points;
	        }

            async function loadPredictedDayPoints(dateText) {
                const response = await fetch(buildApiUrl('/api/predict/day', {
                    user_id: userId,
                    date: dateText
                }));

                if (!response.ok) {
                    throw new Error('Failed to load day prediction');
                }

                const payload = await response.json();
                const prediction = payload.data || {};

                return (prediction.predicted_schedule || [])
                    .filter(function(point) {
                        return Number.isFinite(Number(point.lat)) && Number.isFinite(Number(point.lng));
                    })
                    .map(function(point) {
                        return {
                            ...point,
                            display_mode: 'prediction_day'
                        };
                    });
            }

            async function loadPredictedTimePoint(dateText, timeText) {
                const response = await fetch(buildApiUrl('/api/predict/time', {
                    user_id: userId,
                    date: dateText,
                    time: timeText
                }));

                if (!response.ok) {
                    throw new Error('Failed to load time prediction');
                }

                const payload = await response.json();
                const point = payload.data && payload.data.prediction;

                if (!point || !Number.isFinite(Number(point.lat)) || !Number.isFinite(Number(point.lng))) {
                    return [];
                }

                return [{
                    ...point,
                    display_mode: 'prediction_time',
                    selected_time: timeText
                }];
            }

            function updateVisitCount(count, label) {
                var visitCountBadge = document.getElementById('visitCountBadge');
                var safeCount = Number(count) || 0;
                var badgeLabel = label || currentBadgeLabel;

                visitCountBadge.textContent = badgeLabel + ': ' + safeCount;
            }

            function getFirstValue(point, keys) {
                for (var index = 0; index < keys.length; index++) {
                    var value = point[keys[index]];

                    if (value !== undefined && value !== null && value !== '') {
                        return value;
                    }
                }

                return null;
            }

            function getTimeMinutes(timeText) {
                if (!timeText) {
                    return null;
                }

                var match = String(timeText).trim().match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);

                if (!match) {
                    return null;
                }

                var hour = Number(match[1]);
                var minute = Number(match[2]);
                var period = match[3].toUpperCase();

                if (period === 'PM' && hour !== 12) {
                    hour += 12;
                }

                if (period === 'AM' && hour === 12) {
                    hour = 0;
                }

                return hour * 60 + minute;
            }

            function formatDurationSeconds(totalSeconds) {
                var seconds = Math.max(0, Math.round(Number(totalSeconds) || 0));
                var hours = Math.floor(seconds / 3600);
                var minutes = Math.floor((seconds % 3600) / 60);

                if (hours && minutes) {
                    return hours + 'h ' + minutes + 'm';
                }

                if (hours) {
                    return hours + 'h';
                }

                if (minutes) {
                    return minutes + 'm';
                }

                return seconds + 's';
            }

            function getVisitStart(point) {
                return getFirstValue(point, ['visit_start_time', 'start_time', 'startTime', 'visit_start']);
            }

            function getVisitEnd(point) {
                return getFirstValue(point, ['visit_end_time', 'end_time', 'endTime', 'visit_end']);
            }

            function getVisitDuration(point) {
                var durationValue = getFirstValue(point, [
                    'duration_sec',
                    'duration_seconds',
                    'durationSec',
                    'stay_duration_sec'
                ]);

                if (durationValue !== null) {
                    return formatDurationSeconds(durationValue);
                }

                durationValue = getFirstValue(point, ['duration', 'visit_duration']);

                if (durationValue !== null) {
                    return String(durationValue);
                }

                var startMinutes = getTimeMinutes(getVisitStart(point));
                var endMinutes = getTimeMinutes(getVisitEnd(point));

                if (startMinutes === null || endMinutes === null) {
                    return '-';
                }

                var durationMinutes = endMinutes - startMinutes;

                if (durationMinutes < 0) {
                    durationMinutes += 24 * 60;
                }

                return formatDurationSeconds(durationMinutes * 60);
            }

            function getPointVisitCount(point) {
                return getFirstValue(point, ['visit_count', 'visitCount']);
            }

            function getClusterRadius(point) {
                return getFirstValue(point, ['radius_meters', 'radiusMeters']);
            }

            function getAverageDuration(point) {
                var durationValue = getFirstValue(point, ['avg_duration_sec', 'avgDurationSec']);

                if (durationValue === null) {
                    return null;
                }

                return formatDurationSeconds(durationValue);
            }

            function getClusterName(point, fallbackLabel) {
                return getFirstValue(point, [
                    'cluster_name',
                    'clusterName',
                    'place_name',
                    'placeName',
                    'cluster_id',
                    'clusterId',
                    'point_name',
                    'pointName',
                    'name'
                ]) || fallbackLabel;
            }

            function getClusterPointCount(point) {
                return getFirstValue(point, [
                    'point_count',
                    'pointCount',
                    'total_cluster_points',
                    'totalClusterPoints',
                    'total_points',
                    'totalPoints'
                ]);
            }

            function getClusterConfidence(point) {
                return getFirstValue(point, [
                    'place_type_confidence',
                    'placeTypeConfidence',
                    'cluster_confidence',
                    'clusterConfidence',
                    'confidence'
                ]);
            }

            function formatConfidence(confidenceValue) {
                if (confidenceValue === null) {
                    return null;
                }

                var confidence = Number(confidenceValue);

                if (Number.isNaN(confidence)) {
                    return String(confidenceValue);
                }

                if (confidence <= 1) {
                    confidence *= 100;
                }

                return Math.round(confidence) + '%';
            }

            function removeMapObject(item) {
                if (!item) {
                    return;
                }

                if (typeof item.remove === 'function') {
                    item.remove();
                    return;
                }

                if (typeof item.setMap === 'function') {
                    item.setMap(null);
                }
            }

            function clearMapOverlays() {
                markers.forEach(removeMapObject);
                polylines.forEach(removeMapObject);
                markers = [];
                polylines = [];
                markerPositions = [];
            }

            function getMarkerPosition(point, duplicateIndex, duplicateCount) {
                var lat = Number(point.lat);
                var lng = Number(point.lng);

                if (duplicateCount <= 1) {
                    return { lat: lat, lng: lng };
                }

                var radiusMeters = 8 + Math.floor(duplicateIndex / 8) * 6;
                var angle = (duplicateIndex / duplicateCount) * Math.PI * 2;
                var latOffset = Math.cos(angle) * radiusMeters / 111320;
                var lngOffset = Math.sin(angle) * radiusMeters / (111320 * Math.cos(lat * Math.PI / 180));

                return {
                    lat: lat + latOffset,
                    lng: lng + lngOffset
                };
            }

            function getPointKey(point) {
                return Number(point.lat).toFixed(7) + '_' + Number(point.lng).toFixed(7);
            }

            function setMapCenter(point) {
                map.setCenter([Number(point.lng), Number(point.lat)]);
            }

            function setActivePoint(pointIndex) {
                document.querySelectorAll('.point-item').forEach(function(item) {
                    item.classList.toggle(
                        'active',
                        Number(item.getAttribute('data-point-index')) === pointIndex
                    );
                });

                document.querySelectorAll('.visit-map-marker').forEach(function(markerElement) {
                    var label = Number(markerElement.getAttribute('data-marker-label'));
                    var isActive = label === pointIndex + 1;
                    var baseColor = markerElement.getAttribute('data-marker-color') || '#1d4ed8';

                    markerElement.style.background = isActive ? '#d93025' : baseColor;
                    markerElement.style.transform = isActive ? 'scale(1.15)' : 'scale(1)';
                });
            }

            function addVisitMarkers(points) {
                var duplicateCounts = {};
                var duplicateSeen = {};

                points.forEach(function(point) {
                    var key = getPointKey(point);
                    duplicateCounts[key] = (duplicateCounts[key] || 0) + 1;
                });

                markerPositions = [];

                markers = points.map(function(point, index) {
                    var label = String(index + 1);
                    var key = getPointKey(point);
                    var duplicateIndex = duplicateSeen[key] || 0;
                    duplicateSeen[key] = duplicateIndex + 1;

                    var position = getMarkerPosition(point, duplicateIndex, duplicateCounts[key]);
                    markerPositions[index] = position;
                    var clusterName = getClusterName(point, 'Point ' + label);
                    var pointCount = getClusterPointCount(point);
                    var confidence = formatConfidence(getClusterConfidence(point));
                    var visitCount = getPointVisitCount(point);
                    var radius = getClusterRadius(point);
                    var avgDuration = getAverageDuration(point);
                    var markerColor = point.display_mode === 'prediction_time' ? '#d93025' : '#1d4ed8';
                    var titlePrefix = point.display_mode === 'prediction_time' ? 'Predicted Point ' : 'Cluster ';
                    var popupHtml = [
                        '<div>',
                        '<strong>' + titlePrefix + label + '</strong><br>',
                        'Cluster: ' + clusterName + '<br>',
                        'Type: ' + (point.place_type || '-') + '<br>',
                        point.start_time ? 'Start: ' + point.start_time + '<br>' : '',
                        point.end_time ? 'End: ' + point.end_time + '<br>' : '',
                        point.selected_time ? 'Selected Time: ' + point.selected_time + '<br>' : '',
                        confidence !== null ? 'Confidence: ' + confidence + '<br>' : '',
                        pointCount !== null ? 'Point Count: ' + pointCount + '<br>' : '',
                        visitCount !== null ? 'Visit Count: ' + visitCount + '<br>' : '',
                        avgDuration !== null ? 'Avg Duration: ' + avgDuration + '<br>' : '',
                        radius !== null ? 'Radius: ' + Math.round(Number(radius)) + 'm<br>' : '',
                        'Lat: ' + Number(point.lat).toFixed(7) + '<br>',
                        'Lng: ' + Number(point.lng).toFixed(7),
                        '</div>'
                    ].join('');

                    return new mappls.Marker({
                        map: map,
                        position: position,
                        popupHtml: popupHtml,
                        draggable: false,
                        html: '<div class="visit-map-marker" data-marker-label="' + label + '" data-marker-color="' + markerColor + '" style="align-items:center;background:' + markerColor + ';border:2px solid #fff;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,.35);color:#fff;display:flex;font:700 13px Arial,sans-serif;height:30px;justify-content:center;min-width:30px;padding:0 4px;transition:background .15s ease,transform .15s ease;white-space:nowrap;">' + label + '</div>'
                    });
                });
            }

            function drawVisitPolyline(points) {
                var displayPath = points.map(function(point, index) {
                    return markerPositions[index] || point;
                });

                polylines = [];
                var seenPointKeys = {};

                if (points.length) {
                    seenPointKeys[getPointKey(points[0])] = true;
                }

                for (var index = 1; index < points.length; index++) {
                    var destinationKey = getPointKey(points[index]);
                    var isReturningToSeenPoint = Boolean(seenPointKeys[destinationKey]);
                    var strokeColor = isReturningToSeenPoint ? '#2563eb' : '#d93025';

                    polylines.push(new mappls.Polyline({
                        map: map,
                        paths: [displayPath[index - 1], displayPath[index]],
                        strokeColor: strokeColor,
                        strokeOpacity: 1.0,
                        strokeWeight: 6,
                        fitbounds: index === 1
                    }));

                    seenPointKeys[destinationKey] = true;
                }
            }
            function renderPointList(points) {
                var pointList = document.getElementById('pointList');

                if (!points.length) {
                    pointList.innerHTML = '<div class="point-list-state">No user clusters found. Generate/process GPS data first, then run clustering.</div>';
                    return;
                }

                pointList.innerHTML = points.map(function(point, index) {
                    var label = String(index + 1);
                    var clusterName = getClusterName(point, 'Point ' + label);
                    var pointCount = getClusterPointCount(point);
                    var confidence = formatConfidence(getClusterConfidence(point));
                    var visitCount = getPointVisitCount(point);
                    var radius = getClusterRadius(point);
                    var avgDuration = getAverageDuration(point);
                    var titlePrefix = point.display_mode === 'prediction_time' ? 'Predicted Point ' : 'Cluster ';

                    return [
                        '<div class="point-item" data-point-index="' + index + '">',
                        '<div class="point-title">' + titlePrefix + label + ' - ' + clusterName + '</div>',
                        '<div class="point-meta">',
                        'Cluster ID: ' + (point.cluster_id || '-') + '<br>',
                        'Type: ' + (point.place_type || '-') + '<br>',
                        point.start_time ? 'Start: ' + point.start_time + '<br>' : '',
                        point.end_time ? 'End: ' + point.end_time + '<br>' : '',
                        point.selected_time ? 'Selected Time: ' + point.selected_time + '<br>' : '',
                        confidence !== null ? 'Confidence: ' + confidence + '<br>' : '',
                        pointCount !== null ? 'Point Count: ' + pointCount + '<br>' : '',
                        visitCount !== null ? 'Visit Count: ' + visitCount + '<br>' : '',
                        avgDuration !== null ? 'Avg Duration: ' + avgDuration + '<br>' : '',
                        radius !== null ? 'Radius: ' + Math.round(Number(radius)) + 'm<br>' : '',
                        'Lat: ' + Number(point.lat).toFixed(7) + '<br>',
                        'Lng: ' + Number(point.lng).toFixed(7),
                        '</div>',
                        '</div>'
                    ].join('');
                }).join('');

                pointList.onclick = function(event) {
                    var item = event.target.closest('.point-item');

                    if (!item) {
                        return;
                    }

                    var pointIndex = Number(item.getAttribute('data-point-index'));
                    var position = markerPositions[pointIndex] || points[pointIndex];

                    if (!position) {
                        return;
                    }

                    setMapCenter(position);
                    map.setZoom(17);
                    setActivePoint(pointIndex);

                    if (window.matchMedia('(max-width: 768px)').matches) {
                        closePointPanel();
                    }
                };
            }

            function renderMapPoints(points, options) {
                var settings = options || {};
                activePoints = points;
                currentBadgeLabel = settings.badgeLabel || 'Point Count';

                clearMapOverlays();
                updateVisitCount(points.length, currentBadgeLabel);
                renderPointList(points);

                if (!points.length) {
                    if (settings.emptyText) {
                        document.getElementById('pointList').innerHTML = '<div class="point-list-state">' + settings.emptyText + '</div>';
                    }
                    return;
                }

                setMapCenter(points[0]);
                addVisitMarkers(points);

                if (settings.drawPolyline !== false && points.length > 1) {
                    drawVisitPolyline(points);
                }

                setActivePoint(0);
            }

            function openPointPanel() {
                document.body.classList.add('panel-open');
                document.getElementById('menuButton').setAttribute('aria-expanded', 'true');
            }

            function closePointPanel() {
                document.body.classList.remove('panel-open');
                document.getElementById('menuButton').setAttribute('aria-expanded', 'false');
            }

            document.getElementById('menuButton').addEventListener('click', openPointPanel);
            document.getElementById('closePanelButton').addEventListener('click', closePointPanel);
            document.getElementById('panelBackdrop').addEventListener('click', closePointPanel);

            function setPredictionLoading(isLoading) {
                document.getElementById('predictDayButton').disabled = isLoading;
                document.getElementById('predictTimeButton').disabled = isLoading;
            }

            function getSelectedDate() {
                return document.getElementById('predictionDate').value ||
                    new Date().toISOString().slice(0, 10);
            }

            function getSelectedTime() {
                return document.getElementById('predictionTime').value;
            }

            async function showPredictedDay() {
                var dateText = getSelectedDate();

                setPredictionLoading(true);
                document.getElementById('pointList').innerHTML = '<div class="point-list-state">Loading predicted day route...</div>';

                try {
                    var points = await loadPredictedDayPoints(dateText);
                    renderMapPoints(points, {
                        badgeLabel: 'Predicted Stops',
                        drawPolyline: true,
                        emptyText: 'No predicted route found for this day.'
                    });
                } catch (error) {
                    console.error(error);
                    clearMapOverlays();
                    updateVisitCount(0, 'Predicted Stops');
                    document.getElementById('pointList').innerHTML = '<div class="point-list-state">Failed to load day prediction.</div>';
                } finally {
                    setPredictionLoading(false);
                }
            }

            async function showPredictedTime() {
                var dateText = getSelectedDate();
                var timeText = getSelectedTime();

                if (!timeText) {
                    document.getElementById('pointList').innerHTML = '<div class="point-list-state">Select a time first.</div>';
                    updateVisitCount(0, 'Predicted Points');
                    return;
                }

                setPredictionLoading(true);
                document.getElementById('pointList').innerHTML = '<div class="point-list-state">Loading predicted point...</div>';

                try {
                    var points = await loadPredictedTimePoint(dateText, timeText);
                    renderMapPoints(points, {
                        badgeLabel: 'Predicted Points',
                        drawPolyline: false,
                        emptyText: 'No predicted point found for this time.'
                    });
                } catch (error) {
                    console.error(error);
                    clearMapOverlays();
                    updateVisitCount(0, 'Predicted Points');
                    document.getElementById('pointList').innerHTML = '<div class="point-list-state">Failed to load time prediction.</div>';
                } finally {
                    setPredictionLoading(false);
                }
            }

            function initializePredictionControls() {
                var dateInput = document.getElementById('predictionDate');
                dateInput.value = new Date().toISOString().slice(0, 10);

                document.getElementById('predictDayButton').addEventListener('click', showPredictedDay);
                document.getElementById('predictTimeButton').addEventListener('click', showPredictedTime);
                dateInput.addEventListener('change', showPredictedDay);
                document.getElementById('predictionTime').addEventListener('change', function() {
                    if (getSelectedTime()) {
                        showPredictedTime();
                    }
                });
            }

	        function initMap1() {
            map = new mappls.Map('map', {
                center: [28.61, 77.23],
                zoomControl: true,
                location: true
            });
            map.setMaxZoom(17.7);
            map.addListener('load', async function() {
            initializePredictionControls();
            var pts = [];

            try {
                pts = await loadUserClusterPoints();
            } catch (error) {
                console.error(error);
                updateVisitCount(0);
                document.getElementById('pointList').innerHTML = '<div class="point-list-state">Failed to load user clusters from /api/user-clusters/polyline.</div>';
                return;
            }

	            if (!pts.length) {
                    renderPointList(pts);
	                return;
	            }

                renderMapPoints(pts, {
                    badgeLabel: 'Cluster Count',
                    drawPolyline: false
                });
        });
        }
    </script>
        </body>
      </html>
      

      
      
    
